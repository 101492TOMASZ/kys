knowledge source baza_regułowa_003

facets

  ask     yes;
  single  yes;

  typ_aktywnosci :
     ask     yes
     single  yes
     val oneof  
     { 
        "kreatywna",
        "rozrywkowa",
        "spoleczna",
        "sportowa",
        "umyslowa"
     }
     picture
     {
        "c:\\users\\tomas\\desktop\\kys\\kreatywna.bmp",
        "c:\\users\\tomas\\desktop\\kys\\rozrywkowa.bmp",
        "c:\\users\\tomas\\desktop\\kys\\spoleczna.bmp",
        "c:\\users\\tomas\\desktop\\kys\\sportowa.bmp",
        "c:\\users\\tomas\\desktop\\kys\\umyslowa.bmp"
     };

  miejsce :
     ask     yes
     single  yes
     val oneof  
     { 
        "w_domu",
        "na_zewnatrz"
     }
     picture
     {
        "c:\\users\\tomas\\desktop\\kys\\wdomu.bmp",
        "c:\\users\\tomas\\desktop\\kys\\nazewnatrz.bmp"
     };

  towarzystwo :
     ask     yes
     single  yes
     val oneof  
     { 
        "sam/sama",
        "z_kims"
     }
     picture
     {
        "c:\\users\\tomas\\desktop\\kys\\samsama.bmp",
        "c:\\users\\tomas\\desktop\\kys\\z kims.bmp"
     };

  polecana_aktywnosc :
     ask     yes
     single  yes
     val oneof  
     { 
        "bieganie",
        "pilka nozna",
        "trening domowy",
        "zajecia fitness",
        "czytanie w parku",
        "nauka grupowa",
        "programowanie",
        "kurs online",
        "fotografia",
        "plener malarski",
        "rysowanie",
        "rekodzielo grupowe",
        "spacer",
        "kino",
        "gra wideo",
        "gra planszowa",
        "wolontariat",
        "spotkanie z przyjaciolmi",
        "rozmowa telefoniczna",
        "impreza domowa"
     }
     picture
     {
        "c:\\users\\tomas\\desktop\\kys\\bieganie.bmp",
        "",
        "",
