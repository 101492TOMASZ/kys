end; // facets

rules

   1001: polecana_aktywnosc = "bieganie" if
             typ_aktywnosci = "sportowa" 
             & miejsce = "na_zewnatrz" 
             & towarzystwo = "sam/sama";

   1002: polecana_aktywnosc = "pilka nozna" if
             typ_aktywnosci = "sportowa" 
             & miejsce = "na_zewnatrz" 
             & towarzystwo = "z_kims";

   1003: polecana_aktywnosc = "trening domowy" if
             typ_aktywnosci = "sportowa" 
             & towarzystwo = "sam/sama" 
             & miejsce = "w_domu";

   1004: polecana_aktywnosc = "zajecia fitness" if
             typ_aktywnosci = "sportowa" 
             & miejsce = "w_domu" 
             & towarzystwo = "z_kims";

   1005: polecana_aktywnosc = "czytanie w parku" if
